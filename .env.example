# ============================================================
# 星鑽 XS 匹克球 — 環境變數範例
# 使用方式：複製此檔為 .env 並填入真實值
# 修改後請重新啟動：npm run dev
# ============================================================

# --- Supabase 資料庫（必填）---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- 管理員登入（必填，對應登入頁帳號）---
ADMIN_USERNAME=Smile
ADMIN_EMAIL=smile@xingzuan-xs.local
ADMIN_PASSWORD=your-admin-password

# --- KHPA 協會共用帳號（選填，/khpa 入口）---
KHPA_USERNAME=KHPA
KHPA_EMAIL=khpa@khpa.local
KHPA_PASSWORD=your-khpa-password

# --- 星鑽 XS 一般使用者共用帳號（選填，/login 一般使用者分頁）---
STAFF_USERNAME=user
STAFF_EMAIL=user@xingzuan-xs.local
STAFF_PASSWORD=your-staff-password

# --- Supabase 管理 API（雲端必填：設定頁建立／更新協會與一般使用者帳號）---
# 本機腳本 npm run create-admin 也需要此金鑰
# Cloudflare：Workers → Variables and Secrets → Secret（執行期，非 Build variable）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DUPR Club 球員同步（選填，球員管理頁「更新 Club 名單」）
# Club ID 也可在管理員「設定」頁調整（星鑽 XS / 協會可分開）
# Cloudflare：Workers → Variables and Secrets（執行期 Secrets），變更後需重新部署
# 方式 A（建議）：用你的 DUPR 官網登入帳密，系統會自動換 Token
DUPR_EMAIL=your-dupr-login-email
DUPR_PASSWORD=your-dupr-login-password
DUPR_CLUB_ID=4668804565

# 方式 B：直接貼 Bearer Token（從瀏覽器開發者工具複製，會過期）
# DUPR_API_TOKEN=eyJhbGciOi...

# DUPR_API_BASE=https://api.dupr.gg
# DUPR_API_VERSION=v1.0
# DUPR_AUTH_VERSION=v2.0

# --- 打球軌跡地址定位（選填）---
# 未設定時使用 Esri + OpenStreetMap 定位；若仍常搜不到台灣門牌可改用 Google
# GOOGLE_GEOCODING_API_KEY=your-google-geocoding-api-key
