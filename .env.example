# ============================================================
# 星鑽 XS 匹克球 — 環境變數範例
# 使用方式：複製此檔為 .env 並填入真實值
# 修改後請重新啟動：npm run dev
# ============================================================

# --- Supabase 資料庫（必填）---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- 管理員登入（必填，對應登入頁帳號）---
ADMIN_USERNAME=Smile
ADMIN_EMAIL=smile@xingzuan-xs.local
ADMIN_PASSWORD=your-admin-password

# --- 僅本機建立管理員腳本用：npm run create-admin ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- DUPR Club 球員同步（選填，球員管理頁「更新 Club 名單」）---
# Cloudflare：Workers → Variables and Secrets（執行期 Secrets），變更後需重新部署
# 方式 A（建議）：用你的 DUPR 官網登入帳密，系統會自動換 Token
DUPR_EMAIL=your-dupr-login-email
DUPR_PASSWORD=your-dupr-login-password
DUPR_CLUB_ID=4668804565

# 方式 B：直接貼 Bearer Token（從瀏覽器開發者工具複製，會過期）
# DUPR_API_TOKEN=eyJhbGciOi...

# DUPR_API_BASE=https://api.dupr.gg
# DUPR_API_VERSION=v1.0
# DUPR_AUTH_VERSION=v2.0
